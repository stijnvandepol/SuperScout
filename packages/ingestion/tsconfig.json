{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // DOM types are needed for the in-page extractors run via Playwright's
    // page.evaluate (browser/*.ts); the worker itself runs on Node.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals", "node"],
    "resolveJsonModule": true
  },
  "include": ["src", "test"]
}
